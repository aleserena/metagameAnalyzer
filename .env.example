# Copy this file to .env (or .env.dev / .env.staging / .env.prod) and fill in values.
# Set DB_ENV=dev|staging|prod to load .env.dev, .env.staging, or .env.prod instead of .env.

# Database (required for PostgreSQL persistence; omit to use in-memory storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/mtgtop8

# Optional: which env file to load (dev, staging, prod)
# DB_ENV=dev

# Directory for data files (decks.json, player_aliases.json, etc.). Relative to project root or absolute.
# DATA_DIR=.

# CORS allowed origins (comma-separated). Default allows Vite dev server.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin login and JWT. Set in production.
# ADMIN_PASSWORD=your-secret-password
# JWT_SECRET=your-jwt-secret

# Public app URL (e.g. for links in emails or redirects)
# PUBLIC_APP_URL=https://your-domain.com

# Feedback form: create GitHub issues from the app (no user GitHub account required).
# GITHUB_TOKEN=ghp_... (Personal Access Token with repo scope, or fine-grained with Issues: Write)
# GITHUB_REPO=owner/repo (e.g. aleserena/metagameAnalyzer). Repo must have labels: bug, enhancement, question.

# Scraper: max parallel workers (1–8). Default 1.
# SCRAPER_MAX_WORKERS=1

# SQL echo (log queries). Set to 1 or true to enable.
# SQL_ECHO=
